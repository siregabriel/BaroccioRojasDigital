# Copia este archivo a ".env" y rellena los valores.
# En el VPS, estas variables las define el servicio systemd (NO subas el .env real).

# Clave secreta de Flask. Genera una con:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=pon-aqui-una-clave-larga-y-aleatoria

# Conexión a PostgreSQL en el VPS:
#   postgresql://USUARIO:CONTRASEÑA@localhost:5432/NOMBRE_BD
DATABASE_URL=postgresql://baroccio:cambia-esto@localhost:5432/baroccio

# Carpeta donde se guardan los documentos subidos (persistente en el VPS)
UPLOAD_DIR=/var/www/baroccio/uploads

# Debug SIEMPRE 0 en producción
FLASK_DEBUG=0

# Evita que la app cree/poble la BD sola (en prod usamos migraciones)
AUTO_INIT_DB=0
